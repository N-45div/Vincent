# Chainlink CRE Workflow Environment Variables
# Copy this to .env and fill in your values

# Ethereum private key for CRE workflow (used for on-chain attestation)
CRE_ETH_PRIVATE_KEY=0x...

# OpenRouter API key for AI decision making
OPENROUTER_API_KEY=sk-or-v1-...

# Supabase credentials for signal storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
