SUPABASE_SERVICE_KEY=your-service-role-key
X402_RECEIVER_ADDRESS=0xYourBaseSepoliaAddress
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_FACILITATOR_API_KEY=your-facilitator-api-key
X402_FACILITATOR_AUTH_HEADER=Authorization
X402_FACILITATOR_AUTH_VALUE=Bearer your-facilitator-api-key
X402_PRICE=$0.01
