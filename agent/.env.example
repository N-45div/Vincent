# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxx

# x402 Signal API endpoint
X402_SIGNAL_URL=http://localhost:4021/api/signals

# Payer wallet private key (Base Sepolia testnet)
PAYER_PRIVATE_KEY=0xYourTestnetPrivateKey

# World ID access token (from /api/world-id/verify)
WORLD_ID_TOKEN=

# Optional: auto-fetch latest token from x402 server
WORLD_ID_TOKEN_URL=http://localhost:4021/api/world-id/token
WORLD_ID_ADMIN_SECRET=dev-admin-secret

# Agent loop interval in seconds
AGENT_INTERVAL=60

# OpenRouter model to use
OPENROUTER_MODEL=openai/gpt-4o
